# ── Database ──────────────────────────────────────────────────────────────────
# Used by docker-compose to create the PostgreSQL container
POSTGRES_USER=medical
POSTGRES_PASSWORD=medical_demo_pass
POSTGRES_DB=medical

# Used by the FastAPI app (points to the db service inside docker network)
DATABASE_URL=postgresql+asyncpg://medical:medical_demo_pass@db:5432/medical

# ── JWT ───────────────────────────────────────────────────────────────────────
# Pre-filled for demo. Replace with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=demo-secret-replace-before-real-production-use
JWT_EXPIRE_MINUTES=60

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty → verification codes are printed to the docker logs.
# docker compose logs api   ← look here for codes in demo mode
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
