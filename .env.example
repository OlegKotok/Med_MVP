# Copy to .env and fill in real values. Never commit .env to source control.
DATABASE_URL=postgresql+asyncpg://medical:CHANGE_ME@localhost:5432/medical

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_EXPIRE_MINUTES=60

# Leave SMTP_HOST empty to use console log mode (demo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Used by docker-compose only
POSTGRES_USER=medical
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=medical
