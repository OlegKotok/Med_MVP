# Copy to .env — already pre-filled for demo. Change passwords for real production.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=medical
POSTGRES_PASSWORD=medical_demo_pass
POSTGRES_DB=medical
DATABASE_URL=postgresql+asyncpg://medical:medical_demo_pass@db:5432/medical

# ── JWT ───────────────────────────────────────────────────────────────────────
# Replace with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=demo-secret-replace-before-real-production-use
JWT_EXPIRE_MINUTES=60

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty → verification codes are printed to docker logs (demo mode).
# docker compose logs api   ← look here for codes in demo mode
#
# ukr.net example (port 465, SSL):
#   SMTP_HOST=smtp.ukr.net
#   SMTP_PORT=465
#   SMTP_USE_SSL=true
#   SMTP_USER=your-address@ukr.net
#   SMTP_PASSWORD=your-password
#   SMTP_FROM=your-address@ukr.net
#
# Gmail example (port 587, STARTTLS):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_SSL=false
#   SMTP_USER=your-address@gmail.com
#   SMTP_PASSWORD=your-app-password
#   SMTP_FROM=your-address@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max auth requests per IP per minute. Set 0 to disable (tests / behind nginx).
RATE_LIMIT_AUTH=10
